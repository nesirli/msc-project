# =============================================================================
# AMR K. pneumoniae Prediction Pipeline
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
.Python
build/
dist/
.eggs/

# --- Jupyter ---
*.ipynb
.ipynb_checkpoints/

# --- Virtual environments ---
.env
.venv
env/
venv/
.conda/
conda-meta/

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- macOS ---
.DS_Store
.AppleDouble
._*
.Spotlight-V100
.Trashes

# --- Snakemake runtime ---
.snakemake/
benchmarks/
slurm-*.out

# --- Logs (runtime, not results) ---
logs/

# =============================================================================
# LARGE DATA FILES — exclude all raw/processed/intermediate sequencing data
# =============================================================================

# Raw reads (downloaded from SRA — reproducible via step 02)
data/raw/

# Trimmed/processed reads (reproduced by step 03)
data/processed/

# Assembly FASTA files (6.3GB — reproduced by step 04)
data/assemblies/

# SNP/VCF files (10-13MB each × 1184 samples — reproduced by step 07)
data/snp/

# AMR analysis outputs (reproduced by step 06)
data/amr/

# Reference databases (downloaded, not committed)
data/reference/kraken2_db/
data/reference/*.fasta
data/reference/*.fa
data/reference/*.fna
data/reference/*.gz
data/reference/*.amb
data/reference/*.ann
data/reference/*.bwt
data/reference/*.pac
data/reference/*.sa
data/reference/*.fai

# =============================================================================
# LARGE RESULTS FILES — exclude binary/large intermediate outputs
# =============================================================================

# Feature matrices (NPZ files — large binary arrays)
results/features/deep_models/*.npz
results/features/*.npz

# Trained model weights (large binary — not needed for reproducibility)
results/models/**/*.pt
results/models/**/*.pkl

# QC HTML reports (large, regenerable)
results/qc/*.html
results/qc/**/*.html
results/qc/fastqc_*/
results/qc/fastp/

# =============================================================================
# KEEP — explicitly include important small files
# =============================================================================

# Metadata (small, essential)
!data/metadata.csv
!data/reference/genome_size.txt

# All results JSON (model metrics, summaries — small and important)
!results/**/*.json

# Feature CSVs (processed features — moderate size, important)
!results/features/**/*.csv
!results/features/metadata_*.csv

# Model performance plots
!results/models/**/*.png
!results/models/**/*.csv

# QC summary reports (keep final MultiQC outputs)
!results/qc/postassembly_multiqc.html
!results/qc/preassembly_multiqc.html
!results/qc/raw_multiqc.html

# Interpretability and ensemble results
!results/interpretability/
!results/ensemble/

# HuggingFace cache (large, downloaded on demand)
.cache/
transformers_cache/

# Temporary files
*.tmp
*.bak
*.backup
temp/
tmp/
scratch/results/snp/combined_snps.csv
