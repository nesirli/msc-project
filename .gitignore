# --- KEEP Important Files ---
# Configuration files
!config/config.yaml
!envs/*.yaml
!docker-compose.yml
!Dockerfile
!.dockerignore

# Small reference files
!data/reference/genome_size.txt
!data/reference/reference_genome
!data/reference/*.fai

# Documentation
!README.md
!docs/*.md
!*.md
!CITATION.cff

# Scripts and workflows
!scripts/
!rules/
!utils/
!Snakefile

# Keep all small result summaries and publication-ready outputs
!results/**/*.json
!results/**/*.tsv
!results/**/*.txt
!results/**/*.md

# Keep small CSV files (< 100MB), small plots, and metrics
!results/**/*.csv
!results/**/*.png
!results/**/*.pdf
!results/**/*.svg

# Keep ensemble and interpretability results (small, important)
!results/ensemble/
!results/interpretability/
!results/batch_correction/

# Explicitly keep small AMR summaries
!results/amr/**/*.json
!results/amr/**/*.tsv
!results/amr/**/*.csv
!results/amr/**/*.txt

# Keep model performance metrics and summaries
!results/models/**/*.json
!results/models/**/*.csv
!results/models/**/*.txt
!results/models/**/metrics/
!results/models/**/plots/

# Small example/test data only
!data/metadata.csv

# Cloud deployment configs (templates only, no secrets)
!scripts/gcp/cloudbuild.yaml
!scripts/gcp/*.sh

# Keep plots if they're small
!results/**/plots_complete.txt
results/**/plots/*.png
results/**/plots/*.pdf
!results/**/plots/*.png.small
!results/**/plots/*.pdf.small